# ---- Database (Neon PostgreSQL) ----
# Pooled connection string used by the app at runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST/veloura?sslmode=require"
# Direct (non-pooled) connection used by Prisma migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST/veloura?sslmode=require"

# ---- Auth (Auth.js / NextAuth v5) ----
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# Public site URL (no trailing slash). Locally: http://localhost:3000
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---- File storage (Vercel Blob) ----
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# ---- Email (Resend) ----
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="Veloura <noreply@veloura.example>"

# ---- SMS / WhatsApp reminders (Twilio) ----
TWILIO_ACCOUNT_SID="ACxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxx"
TWILIO_FROM_NUMBER="+1xxxxxxxxxx"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ---- Seed admin (used by prisma/seed.ts) ----
SEED_ADMIN_EMAIL="aboadeeb10@gmail.com"
SEED_ADMIN_PASSWORD="change-me-after-first-login"
